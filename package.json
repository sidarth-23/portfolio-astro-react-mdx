{
  "name": "portfolio-astro-react",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.2.0",
  "private": true,
  "scripts": {
    "preinstall": "bun -e \"const exec = process.env.npm_execpath || ''; if (!exec.includes('bun')) { console.error('Use bun (or bunx), not npm/yarn/pnpm'); process.exit(1); } const min = [1,2,0]; const cur = (process.versions.bun || '0.0.0').split('.').map((n) => Number.parseInt(n, 10) || 0); for (let i = 0; i < 3; i += 1) { if (cur[i] > min[i]) break; if (cur[i] < min[i]) { console.error('Bun >= 1.2.0 is required. Current: ' + (process.versions.bun || 'unknown')); process.exit(1); } }\"",
    "dev": "astro dev",
    "build": "astro build",
    "start": "bun ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,astro}\"",
    "typecheck": "astro check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/node": "^10.1.1",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@data-slot/dialog": "^0.2.166",
    "@data-slot/dropdown-menu": "^0.2.166",
    "@data-slot/tooltip": "^0.2.166",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.100.11",
    "astro": "^6.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-static": "^1.16.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "simple-icons": "^16.20.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "topbar": "^3.0.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gray-matter": "^4.0.3",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-slug": "^6.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.1",
    "vite": "7.3.3",
    "vitest": "^4.1.7"
  }
}
