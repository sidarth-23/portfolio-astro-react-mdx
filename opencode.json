{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "astro-docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp"
    },
    "dokploy-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@dokploy/mcp"],
      "environment": {
        "DOKPLOY_API_KEY": "${DOKPLOY_API_KEY}",
        "DOKPLOY_URL": "${DOKPLOY_URL}"
      }
    }
  }
}
