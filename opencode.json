{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "astro-docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp"
    },
    "dokploy-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@dokploy/mcp"],
      "environment": {
        "DOKPLOY_API_KEY": "{env:DOKPLOY_API_KEY}",
        "DOKPLOY_URL": "{env:DOKPLOY_URL}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
