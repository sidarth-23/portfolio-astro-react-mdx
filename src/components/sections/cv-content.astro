---
import { HugeiconsIcon } from "@hugeicons/react"
import {
  Briefcase01Icon,
  Award03Icon,
  Layers01Icon,
} from "@hugeicons/core-free-icons"
import {
  Timeline,
  TimelineContent,
  TimelineDate,
  TimelineHeader,
  TimelineIndicator,
  TimelineItem,
  TimelineSeparator,
  TimelineTitle,
} from "@/components/reui/timeline"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { Table, TableBody, TableCell, TableRow } from "@/components/ui/table"
import { SkillIcon } from "@/components/icons/skill-icons"
import avatarImage from "@/assets/images/avatar.jpg"
import type { CollectionEntry } from "astro:content"

type CvData = CollectionEntry<"cv">["data"]

type ExperienceRole = {
  title: string
  location?: string
  start: string
  end?: string | null
  currentlyWorking: boolean
  highlights: string[]
}

type ExperienceData = {
  id: number
  locale: "en" | "es" | "fr"
  company: string
  location: string
  roles: ExperienceRole[]
}

type ExperienceItem = {
  data: ExperienceData
}

interface Props {
  data: CvData
  experiences: ExperienceItem[]
}

const { data, experiences } = Astro.props

function formatMonthLabel(value: string): string {
  const [year, month] = value.split("-")
  const date = new Date(Number(year), Number(month) - 1)
  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(date)
}

function getPeriodLabel(
  start: string,
  end: string | null | undefined,
  currentlyWorking: boolean
): string {
  const from = formatMonthLabel(start)
  const to = currentlyWorking ? "Present" : formatMonthLabel(end as string)
  return `${from} - ${to}`
}

function getExperiencePeriodLabel(roles: ExperienceRole[]): string {
  const sortedRoles = [...roles].sort((a, b) =>
    a.start < b.start ? -1 : a.start > b.start ? 1 : 0
  )

  const firstRole = sortedRoles[0]
  const currentRole = sortedRoles.find((role) => role.currentlyWorking)
  const lastRole = sortedRoles[sortedRoles.length - 1]

  return getPeriodLabel(
    firstRole.start,
    currentRole ? null : lastRole.end,
    Boolean(currentRole)
  )
}
---

<div class="space-y-14">
  <Card
    className="border-primary/20 bg-linear-to-br from-card via-card to-primary/5"
  >
    <CardHeader>
      <div class="flex items-center gap-4">
        <img
          src={avatarImage.src}
          alt={data.profile.name}
          class="size-14 rounded-full object-cover ring-1 ring-border md:size-16"
          loading="eager"
          decoding="async"
        />
        <div>
          <CardTitle className="text-xl md:text-2xl"
            >{data.profile.name}</CardTitle
          >
          <CardDescription className="text-sm"
            >{data.profile.role}</CardDescription
          >
        </div>
      </div>
    </CardHeader>
    <CardContent className="space-y-4">
      <CardDescription className="max-w-3xl text-sm leading-6">
        {data.profile.summary}
      </CardDescription>
      <div class="flex flex-wrap gap-2">
        {
          data.profile.focus.map((item) => (
            <Badge variant="secondary">{item}</Badge>
          ))
        }
      </div>
    </CardContent>
  </Card>

  <section class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Briefcase01Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Experience
      </h2>
    </div>

    <Timeline defaultValue={experiences.length} className="w-full">
      {
        experiences.map(({ data: item }) => (
          <TimelineItem
            step={item.id}
            className="group-data-[orientation=vertical]/timeline:ms-10"
          >
            <TimelineHeader>
              <TimelineSeparator className="group-data-[orientation=vertical]/timeline:-left-7 group-data-[orientation=vertical]/timeline:h-[calc(100%-1.5rem-0.25rem)] group-data-[orientation=vertical]/timeline:translate-y-6.5" />
              <TimelineTitle className="mt-0.5 text-base font-semibold">
                {item.company}
              </TimelineTitle>
              <TimelineIndicator className="flex size-6 items-center justify-center border-none bg-primary/10 group-data-completed/timeline-item:bg-primary group-data-completed/timeline-item:text-primary-foreground group-data-[orientation=vertical]/timeline:-left-7">
                <HugeiconsIcon
                  icon={Briefcase01Icon}
                  size={14}
                  strokeWidth={2}
                />
              </TimelineIndicator>
            </TimelineHeader>

            <TimelineContent>
              <p class="text-sm font-medium text-foreground">{item.location}</p>
              <TimelineDate className="mt-1 mb-4">
                {getExperiencePeriodLabel(item.roles)}
              </TimelineDate>

              <Card size="sm" className="border-border/70">
                <CardContent className="py-4">
                  {item.roles.length > 1 ? (
                    <Timeline
                      defaultValue={item.roles.length}
                      className="w-full"
                    >
                      {item.roles.map((role, index) => (
                        <TimelineItem
                          step={index + 1}
                          className="group-data-[orientation=vertical]/timeline:ms-8"
                        >
                          <TimelineHeader>
                            <TimelineSeparator className="group-data-[orientation=vertical]/timeline:-left-5" />
                            <TimelineTitle className="mt-0.5 text-sm font-semibold text-foreground">
                              {role.title}
                            </TimelineTitle>
                            <TimelineIndicator className="size-3 border-primary/30 bg-background group-data-completed/timeline-item:border-primary group-data-completed/timeline-item:bg-primary group-data-[orientation=vertical]/timeline:-left-5" />
                          </TimelineHeader>

                          <TimelineContent>
                            <TimelineDate className="mt-1 mb-2 text-xs">
                              {getPeriodLabel(
                                role.start,
                                role.end,
                                role.currentlyWorking
                              )}
                            </TimelineDate>
                            {role.location && (
                              <p class="mb-2 text-xs font-medium text-foreground">
                                {role.location}
                              </p>
                            )}
                            <ul class="list-disc space-y-1 pl-4 text-sm text-muted-foreground">
                              {role.highlights.map((highlight) => (
                                <li>{highlight}</li>
                              ))}
                            </ul>
                          </TimelineContent>
                        </TimelineItem>
                      ))}
                    </Timeline>
                  ) : (
                    item.roles.map((role) => (
                      <div class="ml-8 space-y-2">
                        <h3 class="text-sm font-semibold text-foreground">
                          {role.title}
                        </h3>
                        <TimelineDate className="mt-1 mb-2 text-xs">
                          {getPeriodLabel(
                            role.start,
                            role.end,
                            role.currentlyWorking
                          )}
                        </TimelineDate>
                        {role.location && (
                          <p class="text-xs font-medium text-foreground">
                            {role.location}
                          </p>
                        )}
                        <ul class="list-disc space-y-1 pl-4 text-sm text-muted-foreground marker:ms-4">
                          {role.highlights.map((highlight) => (
                            <li>{highlight}</li>
                          ))}
                        </ul>
                      </div>
                    ))
                  )}
                </CardContent>
              </Card>
            </TimelineContent>
          </TimelineItem>
        ))
      }
    </Timeline>
  </section>

  <section class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Layers01Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Technologies & Skills
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        data.skills.map((group) => (
          <Card size="sm" className="h-full">
            <CardHeader>
              <CardTitle>{group.title}</CardTitle>
            </CardHeader>
            <CardContent className="flex flex-wrap gap-2">
              {group.items.map((skill) => (
                <Badge variant="outline" className="gap-1.5">
                  <SkillIcon icon={skill.icon} />
                  {skill.label}
                </Badge>
              ))}
            </CardContent>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Award03Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Certifications
      </h2>
    </div>
    <Card size="sm" className="max-w-2xl border-primary/20">
      <CardContent className="pt-1">
        <Table>
          <TableBody>
            {
              data.certifications.map((cert) => (
                <TableRow>
                  <TableCell className="font-medium text-foreground">
                    <a
                      href={cert.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="underline-offset-4 transition hover:underline"
                      aria-label={`Open ${cert.title}`}
                    >
                      {cert.title}
                    </a>
                  </TableCell>
                  <TableCell className="w-12 text-right">
                    <a
                      href={cert.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-muted-foreground transition hover:text-foreground"
                      aria-label={`Open ${cert.title}`}
                      title={`Open ${cert.title}`}
                    >
                      ↗
                    </a>
                  </TableCell>
                </TableRow>
              ))
            }
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>
</div>
