---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"

interface Props {
  src: ImageMetadata
  alt: string
  width: number
  height: number
  fit?: "cover" | "contain"
  class?: string
  imageClass?: string
  blurScaleClass?: string
  loading?: "lazy" | "eager"
  decoding?: "async" | "sync" | "auto"
  format?: "avif" | "png" | "webp" | "jpeg" | "jpg"
}

const {
  src,
  alt,
  width,
  height,
  fit = "cover",
  class: className = "",
  imageClass = "",
  blurScaleClass = "scale-110",
  loading = "lazy",
  decoding = "async",
  format = "webp",
} = Astro.props as Props
---

<div class={`relative overflow-hidden bg-black/5 ${className}`}>
  <Image
    src={src}
    alt=""
    aria-hidden="true"
    width={64}
    height={36}
    quality={25}
    fit="cover"
    format={format}
    loading={loading}
    decoding={decoding}
    class={`absolute inset-0 h-full w-full object-cover blur-2xl ${blurScaleClass}`}
  />
  <Image
    src={src}
    alt={alt}
    width={width}
    height={height}
    fit={fit}
    format={format}
    loading={loading}
    decoding={decoding}
    class={`relative z-10 h-full w-full object-${fit} ${imageClass}`}
  />
</div>
