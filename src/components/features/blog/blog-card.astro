---
import BlurBackdropImage from "@/components/providers/blur-backdrop-image.astro"
import type { CollectionEntry } from "astro:content"
import { Badge } from "@/components/ui/astro/badge"
import { formatShortDate } from "@/lib/content"
import type { Locale } from "@/i18n/config"
import { createBlogCardView } from "@/components/features/listing/card-presenters"
import { HugeiconsIcon } from "@hugeicons/react"
import { ArrowRight01Icon } from "@hugeicons/core-free-icons"

interface Props {
  post: CollectionEntry<"blog">
  locale: Locale
  variant?: "default" | "compact" | "featured"
}

const { post, locale, variant = "default" } = Astro.props

const card = createBlogCardView({
  locale,
  slug: post.id.split("/").slice(1).join("/"),
  title: post.data.title,
  category: post.data.category,
  formattedDate: formatShortDate(post.data.date, locale),
  description: post.data.description,
  tags: post.data.tags,
  coverImage: {
    src: post.data.coverImage.src,
    width: post.data.coverImage.width,
    height: post.data.coverImage.height,
  },
})

const isFeatured = variant === "featured"
const isCompact = variant === "compact"
---

<a href={card.href} class="group block h-full">
  {
    isFeatured ? (
      <article class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-colors transition-shadow hover:shadow-md hover:ring-foreground/20 sm:flex-row">
        <div class="sm:w-[55%]">
          <BlurBackdropImage
            src={post.data.coverImage}
            alt={post.data.title}
            width={800}
            height={450}
            class="aspect-video h-full w-full sm:aspect-auto"
            imageClass="transition-transform duration-300"
          />
        </div>
        <div class="flex flex-1 flex-col p-6 sm:p-8">
          {card.category && (
            <Badge variant="default" class="mb-3 w-fit capitalize">
              {card.category}
            </Badge>
          )}
          <h3 class="text-xl leading-snug font-medium sm:text-2xl">
            {card.title}
          </h3>
          <div class="mt-2">
            <Badge variant="outline" class="w-fit text-muted-foreground/80">
              {card.formattedDate}
            </Badge>
          </div>
          <p class="mt-4 line-clamp-3 flex-1 text-sm leading-relaxed text-muted-foreground/80">
            {card.description}
          </p>
          {card.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {card.tags.map((tag) => (
                <Badge variant="secondary">#{tag}</Badge>
              ))}
            </div>
          )}
          <div class="mt-auto flex justify-end pt-5">
            <HugeiconsIcon
              icon={ArrowRight01Icon}
              size={20}
              strokeWidth={2}
              className="text-primary transition-transform group-hover:translate-x-1"
            />
          </div>
        </div>
      </article>
    ) : (
      <article class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-colors transition-shadow hover:shadow-md hover:ring-foreground/20">
        <BlurBackdropImage
          src={post.data.coverImage}
          alt={post.data.title}
          width={600}
          height={340}
          class="aspect-video w-full"
          imageClass="transition-transform duration-300"
        />
        <div class="flex flex-1 flex-col p-5">
          {card.category && (
            <Badge variant="default" class="mb-2 w-fit capitalize">
              {card.category}
            </Badge>
          )}
          <h3 class="text-lg leading-snug font-medium">{card.title}</h3>
          <div class="mt-2">
            <Badge variant="outline" class="w-fit text-muted-foreground/80">
              {card.formattedDate}
            </Badge>
          </div>

          {!isCompact && (
            <p class="mt-3 line-clamp-2 flex-1 text-sm text-muted-foreground/80">
              {card.description}
            </p>
          )}

          {!isCompact && card.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {card.tags.map((tag) => (
                <Badge variant="secondary">#{tag}</Badge>
              ))}
            </div>
          )}

          <div class="mt-auto flex justify-end pt-4">
            <HugeiconsIcon
              icon={ArrowRight01Icon}
              size={20}
              strokeWidth={2}
              className="text-primary transition-transform group-hover:translate-x-1"
            />
          </div>
        </div>
      </article>
    )
  }
</a>
