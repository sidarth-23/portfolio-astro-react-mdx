---
import { HugeiconsIcon } from "@hugeicons/react"
import { ArrowUpRight01Icon } from "@hugeicons/core-free-icons"

interface Props {
  heading: string
  role: string
  description: string
  buttons: {
    primary: {
      text: string
      url: string
      className?: string
    }
    secondary: {
      text: string
      url: string
      isExternal: boolean
    }
  }
  className?: string
}

const { heading, role, description, buttons, className } = Astro.props
---

<section
  class:list={[
    "relative flex min-h-[70svh] items-center overflow-hidden",
    className,
  ]}
>
  <!-- dot grid background -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(var(--color-border)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_40%,black_35%,transparent_80%)] [background-size:24px_24px]"
  >
  </div>

  <!-- spotlight -->
  <svg
    aria-hidden="true"
    class="pointer-events-none absolute -top-40 left-0 -z-10 h-[169%] w-[138%] animate-spotlight opacity-0 motion-reduce:animate-none motion-reduce:opacity-100 lg:-top-80 lg:left-60 lg:w-[84%]"
    viewBox="0 0 3787 2842"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g filter="url(#hero-spotlight-blur)">
      <ellipse
        cx="1924.71"
        cy="273.501"
        rx="1924.71"
        ry="273.501"
        transform="matrix(-0.822377 -0.568943 -0.568943 0.822377 3631.88 2291.09)"
        class="fill-zinc-700/10 dark:fill-white/20"></ellipse>
    </g>
    <defs>
      <filter
        id="hero-spotlight-blur"
        x="0.860352"
        y="0.838989"
        width="3785.16"
        height="2840.26"
        filterUnits="userSpaceOnUse"
        color-interpolation-filters="sRGB"
      >
        <feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood>
        <feBlend
          mode="normal"
          in="SourceGraphic"
          in2="BackgroundImageFix"
          result="shape"></feBlend>
        <feGaussianBlur stdDeviation="151" result="effect1_foregroundBlur"
        ></feGaussianBlur>
      </filter>
    </defs>
  </svg>

  <div class="container">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <h1 class="mt-6 text-4xl font-bold text-pretty lg:text-6xl xl:text-7xl">
        {heading}
      </h1>
      <p class="mt-2 text-lg font-medium text-primary lg:text-xl">
        {role}
      </p>
      <p
        class="mt-6 mb-12 max-w-xl leading-relaxed text-muted-foreground lg:text-lg"
      >
        {description}
      </p>
      <div class="flex w-full flex-col justify-center gap-3 sm:flex-row">
        <a
          href={buttons.primary.url}
          class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80 sm:w-auto"
        >
          {buttons.primary.text}
        </a>
        <a
          href={buttons.secondary.url}
          target={buttons.secondary.isExternal ? "_blank" : undefined}
          rel={buttons.secondary.isExternal ? "noopener noreferrer" : undefined}
          class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted hover:text-foreground sm:w-auto dark:border-input dark:bg-input/30"
        >
          {buttons.secondary.text}
          <HugeiconsIcon
            icon={ArrowUpRight01Icon}
            size={16}
            strokeWidth={2}
            className="size-4"
          />
        </a>
      </div>
    </div>
  </div>
</section>
