---
import { HugeiconsIcon } from "@hugeicons/react"
import {
  Briefcase01Icon,
  Award03Icon,
  Layers01Icon,
  LinkSquare02Icon,
} from "@hugeicons/core-free-icons"
import {
  Timeline,
  TimelineContent,
  TimelineDate,
  TimelineHeader,
  TimelineIndicator,
  TimelineItem,
  TimelineSeparator,
  TimelineTitle,
} from "@/components/reui/timeline"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/astro/card"
import { Badge } from "@/components/ui/astro/badge"
import { SkillIcon } from "@/components/icon/skill-icons"
import avatarImage from "@/assets/images/avatar.jpg"
import { Image } from "astro:assets"
import { createMarkdownProcessor } from "@astrojs/markdown-remark"
import type { ProfileLocaleContent } from "@/content/content.types"
import { slugify } from "@/lib/search/slugify"

type ExperienceRole = {
  title: string
  location?: string
  start: string
  end?: string | null
  currentlyWorking: boolean
  details: string
}

type ExperienceData = {
  id: number
  locale: "en" | "es" | "fr"
  company: string
  location: string
  roles: ExperienceRole[]
}

type ExperienceItem = {
  data: ExperienceData
}

interface Props {
  data: ProfileLocaleContent
  experiences: ExperienceItem[]
}

const { data, experiences } = Astro.props
const markdownProcessor = await createMarkdownProcessor()

function formatMonthLabel(value: string): string {
  const [year, month] = value.split("-")
  const date = new Date(Number(year), Number(month) - 1)
  return new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(date)
}

function getPeriodLabel(
  start: string,
  end: string | null | undefined,
  currentlyWorking: boolean
): string {
  const from = formatMonthLabel(start)
  const to = currentlyWorking ? "Present" : formatMonthLabel(end as string)
  return `${from} - ${to}`
}

function getExperiencePeriodLabel(roles: ExperienceRole[]): string {
  const sortedRoles = [...roles].sort((a, b) =>
    a.start < b.start ? -1 : a.start > b.start ? 1 : 0
  )

  const firstRole = sortedRoles[0]
  const currentRole = sortedRoles.find((role) => role.currentlyWorking)
  const lastRole = sortedRoles[sortedRoles.length - 1]

  return getPeriodLabel(
    firstRole.start,
    currentRole ? null : lastRole.end,
    Boolean(currentRole)
  )
}

async function renderMarkdownToHtml(markdown: string): Promise<string> {
  return (await markdownProcessor.render(markdown)).code
}

const experiencesWithRoleDetails = await Promise.all(
  experiences.map(async (experience) => ({
    ...experience,
    data: {
      ...experience.data,
      roles: await Promise.all(
        experience.data.roles.map(async (role) => ({
          ...role,
          detailsHtml: await renderMarkdownToHtml(role.details),
        }))
      ),
    },
  }))
)
---

<div class="space-y-14">
  <section id="overview" class="space-y-6">
    <Card
      class="border-primary/20 bg-linear-to-br from-card via-card to-primary/5"
    >
      <CardHeader>
        <div class="flex items-center gap-4">
          <Image
            src={avatarImage}
            alt={data.profile.name}
            width={64}
            height={64}
            format="webp"
            quality={80}
            class="size-14 rounded-full object-cover ring-1 ring-border md:size-16"
            loading="eager"
            decoding="async"
          />
          <div>
            <CardTitle class="text-xl md:text-2xl"
              >{data.profile.name}</CardTitle
            >
            <CardDescription class="text-base"
              >{data.profile.role}</CardDescription
            >
          </div>
        </div>
      </CardHeader>
      <CardContent class="space-y-4">
        <CardDescription class="max-w-3xl text-base leading-6">
          {data.profile.summary}
        </CardDescription>
        <div class="flex flex-wrap gap-2">
          {
            data.profile.focus.map((item) => (
              <Badge variant="secondary">{item}</Badge>
            ))
          }
        </div>
      </CardContent>
    </Card>
  </section>

  <section id="experience" class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Briefcase01Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Experience
      </h2>
    </div>

    <Timeline defaultValue={experiences.length} className="w-full">
      {
        experiencesWithRoleDetails.map(({ data: item }, itemIndex) => (
          <TimelineItem
            step={item.id}
            className="group-data-[orientation=vertical]/timeline:ms-10 group-data-[orientation=vertical]/timeline:pb-10"
          >
            <TimelineHeader>
              <TimelineSeparator
                className={`group-data-completed/timeline-item:bg-primary group-data-[orientation=vertical]/timeline:-left-7 group-data-[orientation=vertical]/timeline:h-[calc(100%-1.5rem-0.25rem)] group-data-[orientation=vertical]/timeline:translate-y-6.5 ${itemIndex === experiencesWithRoleDetails.length - 1 ? "hidden!" : "block!"}`}
              />
              <TimelineTitle className="mt-0.5 text-base font-semibold">
                {item.company}
              </TimelineTitle>
              <TimelineIndicator className="flex size-6 items-center justify-center border-none bg-primary/10 group-data-completed/timeline-item:bg-primary group-data-completed/timeline-item:text-primary-foreground group-data-[orientation=vertical]/timeline:-left-7">
                <HugeiconsIcon
                  icon={Briefcase01Icon}
                  size={14}
                  strokeWidth={2}
                />
              </TimelineIndicator>
            </TimelineHeader>

            <TimelineContent>
              <p class="text-base font-medium text-foreground">
                {item.location}
              </p>
              <TimelineDate className="mt-1 mb-4">
                {getExperiencePeriodLabel(item.roles)}
              </TimelineDate>

              <div class="space-y-6">
                {item.roles.map((role, index) => (
                  <div
                    id={`experience-${item.id}-${index}`}
                    class={index > 0 ? "border-t border-border/40 pt-6" : ""}
                  >
                    <h4 class="text-base font-semibold text-foreground">
                      {role.title}
                    </h4>
                    <TimelineDate className="mt-1 mb-1 text-sm">
                      {getPeriodLabel(
                        role.start,
                        role.end,
                        role.currentlyWorking
                      )}
                    </TimelineDate>
                    {role.location && (
                      <p class="mb-2 text-sm font-medium text-foreground">
                        {role.location}
                      </p>
                    )}
                    <div class="ml-3 max-w-none text-base text-muted-foreground [&_li]:my-1 [&_ol]:my-2 [&_ol]:list-decimal [&_ol]:pl-5 [&_p]:my-2 [&_ul]:my-2 [&_ul]:list-disc [&_ul]:pl-5">
                      <div set:html={role.detailsHtml} />
                    </div>
                  </div>
                ))}
              </div>
            </TimelineContent>
          </TimelineItem>
        ))
      }
    </Timeline>
  </section>

  <section id="technologies-skills" class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Layers01Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Technologies & Skills
      </h2>
    </div>

    <Card size="sm" class="max-w-3xl">
      <CardContent class="divide-y divide-border/40">
        {
          data.skills.map((group) => (
            <div
              id={`skills-${slugify(group.title)}`}
              class="py-4 first:pt-3 last:pb-3"
            >
              <h3 class="mb-3 text-base font-semibold">{group.title}</h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((skill) => (
                  <Badge variant="outline" class="gap-1.5">
                    <SkillIcon icon={skill.icon} />
                    {skill.label}
                  </Badge>
                ))}
              </div>
            </div>
          ))
        }
      </CardContent>
    </Card>
  </section>

  <section id="certifications" class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Award03Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Certifications
      </h2>
    </div>
    <div class="max-w-2xl divide-y divide-border/40">
      {
        data.certifications.map((cert) => (
          <a
            href={cert.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between py-3 text-base font-medium text-foreground underline-offset-4 transition hover:underline"
            aria-label={`Open ${cert.title}`}
          >
            {cert.title}
            <HugeiconsIcon
              icon={LinkSquare02Icon}
              size={16}
              strokeWidth={2}
              className="text-muted-foreground transition group-hover:text-foreground"
            />
          </a>
        ))
      }
    </div>
  </section>
</div>
