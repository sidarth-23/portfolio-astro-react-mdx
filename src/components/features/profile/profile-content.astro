---
import { HugeiconsIcon } from "@hugeicons/react"
import {
  Award03Icon,
  Layers01Icon,
  LinkSquare02Icon,
} from "@hugeicons/core-free-icons"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/astro/card"
import { Badge } from "@/components/ui/astro/badge"
import { Separator } from "@/components/ui/astro/separator"
import { SkillIcon } from "@/components/icon/skill-icons"
import avatarImage from "@/assets/images/avatar.jpg"
import { Image } from "astro:assets"
import { slugify } from "@/lib/search/slugify"
import type { z } from "astro/zod"
import type { profileFrontmatterSchema } from "@/lib/schemas"

type ProfileData = z.infer<typeof profileFrontmatterSchema>

interface Props {
  data: ProfileData
}

const { data } = Astro.props
---

<div class="space-y-12">
  <section id="overview">
    <Card
      class="border-primary/20 bg-linear-to-br from-card via-card to-primary/5"
    >
      <CardHeader>
        <div class="flex items-center gap-4">
          <Image
            src={avatarImage}
            alt={data.name}
            width={64}
            height={64}
            format="webp"
            quality={80}
            class="size-14 rounded-full object-cover ring-1 ring-border md:size-16"
            loading="eager"
            decoding="async"
          />
          <div>
            <CardTitle class="text-xl md:text-2xl">{data.name}</CardTitle>
            <CardDescription class="text-base">{data.role}</CardDescription>
          </div>
        </div>
      </CardHeader>
      <CardContent class="space-y-4">
        <CardDescription class="max-w-3xl text-base leading-6">
          {data.tagline}
        </CardDescription>
        <div class="flex flex-wrap gap-2">
          {data.focus.map((item) => <Badge variant="secondary">{item}</Badge>)}
        </div>
      </CardContent>
    </Card>
  </section>

  <section
    class="prose prose-base max-w-none prose-zinc dark:prose-invert prose-headings:tracking-tight"
  >
    <slot />
  </section>

  <Separator />

  <section id="technologies-skills" class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Layers01Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Technologies & Skills
      </h2>
    </div>

    <Card size="sm">
      <CardContent class="divide-y divide-border/40">
        {
          data.skills.map((group) => (
            <div
              id={`skills-${slugify(group.title)}`}
              class="py-4 first:pt-3 last:pb-3"
            >
              <h3 class="mb-3 text-base font-semibold">{group.title}</h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((skill) => (
                  <Badge variant="outline" class="gap-1.5">
                    <SkillIcon icon={skill.icon} />
                    {skill.label}
                  </Badge>
                ))}
              </div>
            </div>
          ))
        }
      </CardContent>
    </Card>
  </section>

  <section id="certifications" class="space-y-6">
    <div class="flex items-center gap-3">
      <HugeiconsIcon icon={Award03Icon} size={20} strokeWidth={2} />
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">
        Certifications
      </h2>
    </div>
    <div class="divide-y divide-border/40">
      {
        data.certifications.map((cert) => (
          <a
            href={cert.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between py-3 text-base font-medium text-foreground underline-offset-4 transition hover:underline"
            aria-label={`Open ${cert.title}`}
          >
            {cert.title}
            <HugeiconsIcon
              icon={LinkSquare02Icon}
              size={16}
              strokeWidth={2}
              className="text-muted-foreground transition group-hover:text-foreground"
            />
          </a>
        ))
      }
    </div>
  </section>
</div>
