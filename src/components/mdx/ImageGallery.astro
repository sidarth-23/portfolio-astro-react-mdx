---
import { getImage } from "astro:assets"
import type { ImageMetadata } from "astro"
import { ImageGalleryCarousel } from "@/components/content/image-gallery-carousel"

interface Props {
  images: ImageMetadata[]
  title?: string
}

const { images, title = "Image Gallery" } = Astro.props as Props

const optimizedImages = await Promise.all(
  images.map(async (image, index) => {
    const [main, blur] = await Promise.all([
      getImage({
        src: image,
        width: 1600,
        format: "webp",
        quality: 80,
      }),
      getImage({
        src: image,
        width: 48,
        format: "webp",
        quality: 25,
      }),
    ])

    return {
      src: main.src,
      blurSrc: blur.src,
      alt: `${title} image ${index + 1}`,
      width: image.width,
      height: image.height,
    }
  })
)
---

<ImageGalleryCarousel client:load images={optimizedImages} />
