---
const nav = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projects" },
]

const current = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? current === "/" : current.startsWith(href)
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-semibold tracking-tight">Sid</a>
    <ul class="flex items-center gap-6 text-sm">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "transition-colors hover:text-foreground",
                isActive(item.href) ? "text-foreground font-medium" : "text-muted-foreground",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
