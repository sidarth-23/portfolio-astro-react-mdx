---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { formatShortDate } from "@/lib/content"
import type { Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

interface Props {
  project: CollectionEntry<"projects">
  locale: Locale
}

const { project, locale } = Astro.props
---

<a
  href={`/${locale}/projects/${project.slug.split("/").slice(1).join("/")}`}
  class="group block h-full"
>
  <article class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-all hover:ring-primary/20">
    <div class="overflow-hidden">
      <Image
        src={project.data.coverImage}
        alt={project.data.title}
        width={600}
        height={340}
        class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
    <div class="flex flex-1 flex-col p-5">
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-lg font-medium leading-snug transition-colors group-hover:text-primary">
          {project.data.title}
        </h3>
        {project.data.featured && (
          <span class="inline-flex shrink-0 items-center rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-primary">
            {t(locale, "projects.featuredLabel")}
          </span>
        )}
      </div>
      <p class="mt-1 text-xs text-muted-foreground">
        {formatShortDate(project.data.date, locale)}
      </p>
      <p class="mt-3 line-clamp-2 text-sm text-muted-foreground/80 flex-1">
        {project.data.summary}
      </p>
      {project.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {project.data.tags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-secondary px-2.5 py-0.5 text-[10px] font-medium text-secondary-foreground">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
