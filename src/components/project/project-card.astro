---
import BlurBackdropImage from "@/components/media/blur-backdrop-image.astro"
import type { CollectionEntry } from "astro:content"
import { Badge } from "@/components/ui/badge/index"
import { formatShortDate } from "@/lib/content"
import type { Locale } from "@/i18n/config"
import { createProjectCardView } from "@/components/shared/card-presenters"

interface Props {
  project: CollectionEntry<"projects">
  locale: Locale
}

const { project, locale } = Astro.props

const card = createProjectCardView({
  locale,
  slug: project.slug.split("/").slice(1).join("/"),
  title: project.data.title,
  featured: project.data.featured,
  formattedDate: formatShortDate(project.data.date, locale),
  summary: project.data.summary,
  tags: project.data.tags,
  coverImage: {
    src: project.data.coverImage.src,
    width: project.data.coverImage.width,
    height: project.data.coverImage.height,
  },
})
---

<a href={card.href} class="group block h-full">
  <article
    class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-all hover:-translate-y-0.5 hover:shadow-md"
  >
    <BlurBackdropImage
      src={project.data.coverImage}
      alt={project.data.title}
      width={600}
      height={340}
      class="aspect-video w-full"
      imageClass="transition-transform duration-300 group-hover:scale-105"
    />
    <div class="flex flex-1 flex-col p-5">
      <div class="flex items-start justify-between gap-2">
        <h3
          class="text-lg leading-snug font-medium transition-colors group-hover:text-primary"
        >
          {card.title}
        </h3>
        {
          card.featured && (
            <Badge variant="secondary" class="shrink-0">
              {card.featuredLabel}
            </Badge>
          )
        }
      </div>
      <div class="mt-1">
        <Badge variant="outline" class="w-fit text-muted-foreground/80">
          {card.formattedDate}
        </Badge>
      </div>
      <p class="mt-3 line-clamp-2 flex-1 text-sm text-muted-foreground/80">
        {card.summary}
      </p>
      {
        card.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {card.tags.map((tag) => (
              <Badge variant="secondary">#{tag}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </article>
</a>
