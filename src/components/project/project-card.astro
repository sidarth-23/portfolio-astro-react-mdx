---
import BlurBackdropImage from "@/components/media/blur-backdrop-image.astro"
import type { CollectionEntry } from "astro:content"
import { Badge } from "@/components/ui/badge"
import { formatShortDate } from "@/lib/content"
import type { Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

interface Props {
  project: CollectionEntry<"projects">
  locale: Locale
}

const { project, locale } = Astro.props
---

<a
  href={`/${locale}/projects/${project.slug.split("/").slice(1).join("/")}`}
  class="group block h-full"
>
  <article
    class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-all hover:-translate-y-0.5 hover:shadow-md"
  >
    <BlurBackdropImage
      src={project.data.coverImage}
      alt={project.data.title}
      width={600}
      height={340}
      class="aspect-video w-full"
      imageClass="transition-transform duration-300 group-hover:scale-105"
    />
    <div class="flex flex-1 flex-col p-5">
      <div class="flex items-start justify-between gap-2">
        <h3
          class="text-lg leading-snug font-medium transition-colors group-hover:text-primary"
        >
          {project.data.title}
        </h3>
        {
          project.data.featured && (
            <Badge variant="secondary" className="shrink-0">
              {t(locale, "projects.featuredLabel")}
            </Badge>
          )
        }
      </div>
      <div class="mt-1">
        <Badge variant="outline" className="w-fit text-muted-foreground/80">
          {formatShortDate(project.data.date, locale)}
        </Badge>
      </div>
      <p class="mt-3 line-clamp-2 flex-1 text-sm text-muted-foreground/80">
        {project.data.summary}
      </p>
      {
        project.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag) => (
              <Badge variant="secondary">#{tag}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </article>
</a>
