---
import BlurBackdropImage from "@/components/media/blur-backdrop-image.astro"
import type { CollectionEntry } from "astro:content"
import { Badge } from "@/components/ui/badge/index"
import { formatShortDate } from "@/lib/content"
import type { Locale } from "@/i18n/config"
import { createBlogCardView } from "@/components/shared/card-presenters"

interface Props {
  post: CollectionEntry<"blog">
  locale: Locale
}

const { post, locale } = Astro.props

const card = createBlogCardView({
  locale,
  slug: post.slug.split("/").slice(1).join("/"),
  title: post.data.title,
  category: post.data.category,
  formattedDate: formatShortDate(post.data.date, locale),
  description: post.data.description,
  coverImage: {
    src: post.data.coverImage.src,
    width: post.data.coverImage.width,
    height: post.data.coverImage.height,
  },
})
---

<a href={card.href} class="group block h-full">
  <article
    class="flex h-full flex-col overflow-hidden rounded-xl bg-card text-card-foreground ring-1 ring-foreground/10 transition-all hover:-translate-y-0.5 hover:shadow-md"
  >
    <BlurBackdropImage
      src={post.data.coverImage}
      alt={post.data.title}
      width={600}
      height={340}
      class="aspect-video w-full"
      imageClass="transition-transform duration-300 group-hover:scale-105"
    />
    <div class="flex flex-1 flex-col p-5">
      {
        card.category && (
          <Badge variant="default" class="mb-2 w-fit capitalize">
            {card.category}
          </Badge>
        )
      }
      <h3
        class="text-lg leading-snug font-medium transition-colors group-hover:text-primary"
      >
        {card.title}
      </h3>
      <div class="mt-2">
        <Badge variant="outline" class="w-fit text-muted-foreground/80">
          {card.formattedDate}
        </Badge>
      </div>
      <p class="mt-3 line-clamp-2 text-sm text-muted-foreground/80">
        {card.description}
      </p>
      <div class="mt-auto pt-4">
        <span class="inline-flex items-center text-sm font-medium text-primary">
          {card.readMoreLabel}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="ml-1 transition-transform group-hover:translate-x-1"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </div>
    </div>
  </article>
</a>
