---
import type { HTMLAttributes } from "astro/types"
import { resolveIcon } from "./icon-registry"

type Props = Omit<HTMLAttributes<"svg">, "name" | "href"> & {
  href?: HTMLAttributes<"a">["href"]
  name?: string | number | null
}

const { name, href, class: className = "size-[1em] text-base", ...props } =
  Astro.props as Props

const Comp = resolveIcon(name, href?.toString())
const iconProps = props as Record<string, unknown>
---

{
  Comp && <Comp class={className} {...iconProps} />
}
