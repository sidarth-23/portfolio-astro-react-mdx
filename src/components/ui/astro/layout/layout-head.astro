---
import type { ImageMetadata } from "astro"
import { getImage } from "astro:assets"
import { SITE_URL } from "astro:env/server"

type Props = {
  name?: string
  title?: string
  description?: string
  image?: {
    src?: ImageMetadata | string
    alt?: string
  }
  noindex?: boolean
  nofollow?: boolean
  canonical?: string
}

const baseUrl = SITE_URL
const pagePathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`
const {
  name,
  title,
  description,
  image,
  noindex,
  nofollow,
  canonical,
  ...props
} = Astro.props

const resolvedCanonical = new URL(canonical || pagePathname, baseUrl).toString()

const toImageMimeType = (format?: string) => {
  if (!format) return undefined
  if (format.includes("/")) return format
  if (format === "jpg") return "image/jpeg"
  return `image/${format}`
}

const transformedImage =
  image?.src && typeof image.src !== "string"
    ? await getImage({
        src: image.src,
        format: "png",
        width: 1200,
        height: 630,
        quality: "medium",
      })
    : undefined

const openGraphImage =
  typeof image?.src === "string"
    ? {
        url: new URL(image.src, baseUrl).toString(),
        alt: image.alt,
      }
    : transformedImage
      ? {
          url: new URL(transformedImage.src, baseUrl).toString(),
          alt: image?.alt,
          width: transformedImage.attributes.width,
          height: transformedImage.attributes.height,
          type: toImageMimeType(transformedImage.attributes.format),
        }
      : undefined

const robots = [
  noindex ? "noindex" : "index",
  nofollow ? "nofollow" : "follow",
].join(",")
---

<head data-slot="layout-head" {...props}>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta charset="utf-8" />
  {title && <title>{title}</title>}
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={resolvedCanonical} />
  <meta name="robots" content={robots} />

  {title && <meta property="og:title" content={title} />}
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:type" content="website" />
  {name && <meta property="og:site_name" content={name} />}
  {openGraphImage && <meta property="og:image" content={openGraphImage.url} />}
  {
    openGraphImage?.alt && (
      <meta property="og:image:alt" content={openGraphImage.alt} />
    )
  }
  {
    openGraphImage?.width && (
      <meta property="og:image:width" content={String(openGraphImage.width)} />
    )
  }
  {
    openGraphImage?.height && (
      <meta
        property="og:image:height"
        content={String(openGraphImage.height)}
      />
    )
  }
  {
    openGraphImage?.type && (
      <meta property="og:image:type" content={openGraphImage.type} />
    )
  }
  {
    openGraphImage?.url?.startsWith("https://") && (
      <meta property="og:image:secure_url" content={openGraphImage.url} />
    )
  }

  {title && <meta name="twitter:title" content={title} />}
  {description && <meta name="twitter:description" content={description} />}
  {openGraphImage && <meta name="twitter:image" content={openGraphImage.url} />}
  <meta
    name="twitter:card"
    content={openGraphImage ? "summary_large_image" : "summary"}
  />

  <slot name="head" />
  <slot />
</head>
