---
import type { HTMLAttributes } from "astro/types"

import "@/styles/global.css"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"html">

const { class: className, lang, ...props } = Astro.props
---

<html
  class={cn(
    "overscroll-none scroll-smooth bg-background text-foreground has-data-[variant=inset]:bg-sidebar",
    className
  )}
  data-slot="layout"
  lang={Astro.currentLocale || "en"}
  {...props}
>
  <slot />
</html>

<style is:global>
  :root {
    --container: 1280px;
    color-scheme: light;
  }

  .dark {
    color-scheme: dark;
  }
</style>
