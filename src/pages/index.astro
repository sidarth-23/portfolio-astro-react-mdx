---
import { Badge } from "@/components/ui/astro/badge"
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
  CardDescription,
} from "@/components/ui/astro/card"
import { Spinner } from "@/components/ui/astro/spinner"
import BaseLayout from "@/layouts/base/BaseLayout.astro"
import { defaultLocale, localeLabels, locales } from "@/i18n/config"
import { getPageSeo } from "@/lib/seo/pages"
import { resolvePageSeo } from "@/lib/seo/resolve"

const targetPath = `/${defaultLocale}`
const siteUrl = Astro.site?.toString() ?? "https://sidshub.in"
const defaultHomeSeo = getPageSeo("home", defaultLocale)
const seo = resolvePageSeo(
  defaultHomeSeo.title,
  defaultHomeSeo.description,
  `${siteUrl}/og/og-home-${defaultLocale}.png`,
  "website",
  defaultLocale,
  siteUrl,
  "/",
  false
)

const homeSeoByLocale = Object.fromEntries(
  locales.map((locale) => {
    const pageSeo = getPageSeo("home", locale)
    return [
      locale,
      {
        title: pageSeo.title,
        description: pageSeo.description,
        ogImage: `${siteUrl}/og/og-home-${locale}.png`,
      },
    ]
  })
)
---

<BaseLayout
  seo={seo}
  locale="en"
  bodyClass="relative min-h-svh overflow-hidden bg-background text-foreground antialiased"
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`5;url=${targetPath}`} />
    <script
      is:inline
      define:vars={{ targetPath, defaultLocale, locales, homeSeoByLocale }}
    >
      const available = new Set(locales)

      const resolveLocale = () => {
        const preferred = navigator.languages?.length
          ? navigator.languages
          : [navigator.language]

        for (const candidate of preferred) {
          const normalized = String(candidate || "").toLowerCase()
          const full = normalized
          const base = normalized.split("-")[0]

          if (available.has(full)) return full
          if (available.has(base)) return base
        }

        return defaultLocale
      }

      const targetLocale = resolveLocale()
      const target = `/${targetLocale}`
      const seoForLocale =
        homeSeoByLocale[targetLocale] || homeSeoByLocale[defaultLocale]

      if (seoForLocale) {
        document.title = seoForLocale.title

        const setMeta = (selector, content) => {
          const node = document.querySelector(selector)
          if (node && content) node.setAttribute("content", content)
        }

        setMeta('meta[name="description"]', seoForLocale.description)
        setMeta('meta[property="og:title"]', seoForLocale.title)
        setMeta('meta[property="og:description"]', seoForLocale.description)
        setMeta('meta[property="og:image"]', seoForLocale.ogImage)
        setMeta('meta[property="og:locale"]', targetLocale)
        setMeta('meta[name="twitter:title"]', seoForLocale.title)
        setMeta('meta[name="twitter:description"]', seoForLocale.description)
        setMeta('meta[name="twitter:image"]', seoForLocale.ogImage)

        const canonical = document.querySelector('link[rel="canonical"]')
        if (canonical) {
          canonical.setAttribute("href", `${window.location.origin}${target}`)
        }
      }

      window.location.replace(target)
    </script>
  </Fragment>

  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute top-8 -left-20 h-72 w-72 rounded-full bg-primary/18 blur-3xl"
    >
    </div>
    <div
      class="absolute -right-12 bottom-0 h-64 w-64 rounded-full bg-chart-2/16 blur-3xl"
    >
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top,theme(colors.background),transparent_55%)]"
    >
    </div>
  </div>

  <main class="relative z-10 grid min-h-svh place-items-center px-6">
    <Card class="w-full max-w-xl border-border/70 bg-card/85 backdrop-blur">
      <CardHeader class="space-y-3">
        <Badge variant="secondary" class="w-fit tracking-[0.16em] uppercase">
          Sid Portfolio
        </Badge>
        <CardTitle class="text-2xl md:text-3xl"
          >Preparing your experience</CardTitle
        >
        <CardDescription class="text-base text-muted-foreground">
          Taking you to {localeLabels[defaultLocale]} content.
        </CardDescription>
      </CardHeader>
      <CardContent class="flex items-center justify-between gap-4">
        <div
          class="inline-flex items-center gap-3 text-sm text-muted-foreground"
        >
          <Spinner class="size-5 text-primary" />
          Redirecting to your localized home...
        </div>
        <Badge variant="outline" class="font-mono text-xs">{targetPath}</Badge>
      </CardContent>
    </Card>
    <noscript>
      <p class="mt-6 text-center text-sm text-muted-foreground">
        JavaScript is disabled. Continue to <a
          class="underline"
          href={targetPath}>{targetPath}</a
        >.
      </p>
    </noscript>
  </main>
</BaseLayout>
