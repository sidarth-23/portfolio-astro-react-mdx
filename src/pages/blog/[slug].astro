---
import BlogPostLayout from "@/layouts/BlogPostLayout.astro"
import { Image } from "astro:assets"
import { getPublishedBlogPosts, formatDate } from "@/lib/content"
import type { CollectionEntry } from "astro:content"

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts()
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<"blog">
}

const { post } = Astro.props
const { Content } = await post.render()

const pubDate = formatDate(post.data.date)
const updatedDate = post.data.updatedDate ? formatDate(post.data.updatedDate) : null
---

<BlogPostLayout post={post}>
  <article class="max-w-none">
    <header class="mb-8">
      <time class="text-sm text-muted-foreground" datetime={post.data.date.toISOString()}>
        {pubDate}
        {
          updatedDate && (
            <span class="ml-2 text-muted-foreground/70">(updated {updatedDate})</span>
          )
        }
      </time>
      <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">{post.data.title}</h1>
      <p class="mt-3 text-lg text-muted-foreground">{post.data.description}</p>
      {
        post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <Image
      src={post.data.coverImage}
      alt={post.data.title}
      width={1200}
      height={630}
      class="mb-10 w-full rounded-xl object-cover"
    />

    <div class="prose prose-zinc max-w-none dark:prose-invert">
      <Content />
    </div>
  </article>
</BlogPostLayout>
