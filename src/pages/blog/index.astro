---
import ContentLayout from "@/layouts/ContentLayout.astro"
import { getPublishedBlogPosts, getAllTags, formatShortDate } from "@/lib/content"

const posts = await getPublishedBlogPosts()
const tags = getAllTags(posts)
---

<ContentLayout title="Blog — Sid">
  <h1 class="text-3xl font-bold tracking-tight mb-2">Blog</h1>
  <p class="text-muted-foreground mb-8">Thoughts on engineering, design, and building things.</p>

  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <div class="flex flex-col gap-8">
    {
      posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block">
          <article class="flex flex-col gap-2 border-b border-border/50 pb-8 last:border-0">
            <time class="text-xs text-muted-foreground/70">{formatShortDate(post.data.date)}</time>
            <h2 class="text-xl font-medium group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-muted-foreground line-clamp-2">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-1 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="text-xs text-muted-foreground/80">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        </a>
      ))
    }
  </div>
</ContentLayout>
