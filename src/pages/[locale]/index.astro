---
import ContentLayout from "@/layouts/content/ContentLayout.astro"
import Hero from "@/components/features/home/hero.astro"
import FeaturedListing from "@/components/features/home/featured-listing.astro"
import heroIllustration from "@/assets/images/hero-illustration.svg"
import { Image } from "astro:assets"
import BlogCard from "@/components/features/blog/blog-card.astro"
import ProjectCard from "@/components/features/projects/project-card.astro"
import { getPublishedBlogPosts, getFeaturedProjects } from "@/lib/content/queries"
import { locales, defaultLocale, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const projects = await getFeaturedProjects(locale)
const latestPosts = posts.slice(0, 3)
---

<ContentLayout
  title={locale === defaultLocale
    ? "Sid — Engineer & Builder"
    : t(locale, "meta.description")}
  locale={locale}
>
  <Hero
    heading={t(locale, "hero.heading")}
    role={t(locale, "hero.role")}
    description={t(locale, "hero.description")}
    buttons={{
      primary: {
        text: t(locale, "hero.connect"),
        url: "https://linkedin.com",
      },
      secondary: {
        text: t(locale, "hero.resume"),
        url: `/${locale}/profile`,
      },
    }}
  >
    <Image
      slot="image"
      src={heroIllustration}
      alt={t(locale, "hero.imageAlt")}
      width={800}
      height={600}
      class="max-h-150 w-full rounded-md object-contain lg:max-h-200 dark:invert"
    />
  </Hero>

  {
    latestPosts.length > 0 && (
      <FeaturedListing
        title={t(locale, "blog.latest")}
        viewAllHref={`/${locale}/blog`}
        viewAllText={t(locale, "blog.viewAll")}
      >
        <BlogCard
          slot="featured"
          variant="featured"
          post={latestPosts[0]}
          locale={locale}
        />
        {latestPosts.slice(1).map((post) => (
          <BlogCard variant="compact" post={post} locale={locale} />
        ))}
      </FeaturedListing>
    )
  }

  {
    projects.length > 0 && (
      <FeaturedListing
        title={t(locale, "projects.featured")}
        viewAllHref={`/${locale}/projects`}
        viewAllText={t(locale, "projects.viewAll")}
      >
        <ProjectCard
          slot="featured"
          variant="featured"
          project={projects[0]}
          locale={locale}
        />
        {projects.slice(1, 3).map((project) => (
          <ProjectCard variant="compact" project={project} locale={locale} />
        ))}
      </FeaturedListing>
    )
  }
</ContentLayout>
