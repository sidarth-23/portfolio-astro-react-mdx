---
import ContentLayout from "@/layouts/ContentLayout.astro"
import Hero from "@/components/sections/hero.astro"
import heroImage from "@/assets/images/hero-image.png"
import BlogCard from "@/components/features/blog/blog-card.astro"
import ProjectCard from "@/components/features/projects/project-card.astro"
import { getPublishedBlogPosts, getFeaturedProjects } from "@/lib/content/queries"
import { locales, defaultLocale, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const projects = await getFeaturedProjects(locale)
const latestPosts = posts.slice(0, 3)
---

<ContentLayout
  title={locale === defaultLocale
    ? "Sid — Engineer & Builder"
    : t(locale, "meta.description")}
  locale={locale}
>
  <Hero
    heading={t(locale, "hero.heading")}
    role={t(locale, "hero.role")}
    description={t(locale, "hero.description")}
    buttons={{
      primary: {
        text: t(locale, "hero.connect"),
        url: "https://linkedin.com",
      },
      secondary: {
        text: t(locale, "hero.resume"),
        url: `/${locale}/profile`,
      },
    }}
    image={heroImage}
    imageAlt={t(locale, "hero.imageAlt")}
  />

  {
    latestPosts.length > 0 && (
      <section class="mb-16">
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 class="text-sm font-semibold tracking-wider text-muted-foreground uppercase">
            {t(locale, "blog.latest")}
          </h2>
          <a
            href={`/${locale}/blog`}
            class="inline-block text-sm font-medium text-primary hover:underline"
          >
            {t(locale, "blog.viewAll")}
          </a>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {latestPosts.map((post) => (
            <BlogCard post={post} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  {
    projects.length > 0 && (
      <section>
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 class="text-sm font-semibold tracking-wider text-muted-foreground uppercase">
            {t(locale, "projects.featured")}
          </h2>
          <a
            href={`/${locale}/projects`}
            class="inline-block text-sm font-medium text-primary hover:underline"
          >
            {t(locale, "projects.viewAll")}
          </a>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {projects.slice(0, 3).map((project) => (
            <ProjectCard project={project} locale={locale} />
          ))}
        </div>
      </section>
    )
  }
</ContentLayout>
