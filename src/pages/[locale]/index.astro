---
import ContentLayout from "@/layouts/ContentLayout.astro"
import { Image } from "astro:assets"
import { Hero } from "@/components/sections/Hero"
import heroImage from "@/assets/images/hero-image.png"
import { getPublishedBlogPosts, getFeaturedProjects, formatShortDate } from "@/lib/content"
import { locales, defaultLocale, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const projects = await getFeaturedProjects(locale)
const latestPosts = posts.slice(0, 3)
---

<ContentLayout
  title={locale === defaultLocale
    ? "Sid — Engineer & Builder"
    : t(locale, "meta.description")}
  locale={locale}
>
  <Hero
    client:load
    heading={t(locale, "hero.heading")}
    role={t(locale, "hero.role")}
    description={t(locale, "hero.description")}
    buttons={{
      primary: {
        text: t(locale, "hero.connect"),
        url: "https://linkedin.com",
      },
      secondary: {
        text: t(locale, "hero.resume"),
        url: "/resume",
      },
    }}
    imageSrc={heroImage.src}
  />

  {
    latestPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="mb-6 text-sm font-semibold tracking-wider text-muted-foreground uppercase">
          {t(locale, "blog.latest")}
        </h2>
        <div class="flex flex-col gap-6">
          {latestPosts.map((post) => (
            <a
              href={`/${locale}/blog/${post.slug.split("/").slice(1).join("/")}`}
              class="group block"
            >
              <article class="flex flex-col gap-2">
                <h3 class="text-lg font-medium transition-colors group-hover:text-primary">
                  {post.data.title}
                </h3>
                <p class="line-clamp-2 text-sm text-muted-foreground">
                  {post.data.description}
                </p>
                <time class="text-xs text-muted-foreground/70">
                  {formatShortDate(post.data.date, locale)}
                </time>
              </article>
            </a>
          ))}
        </div>
        <a
          href={`/${locale}/blog`}
          class="mt-6 inline-block text-sm font-medium text-primary hover:underline"
        >
          {t(locale, "blog.viewAll")}
        </a>
      </section>
    )
  }

  {
    projects.length > 0 && (
      <section>
        <h2 class="mb-6 text-sm font-semibold tracking-wider text-muted-foreground uppercase">
          {t(locale, "projects.featured")}
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {projects.slice(0, 4).map((project) => (
            <a
              href={`/${locale}/projects/${project.slug.split("/").slice(1).join("/")}`}
              class="group block"
            >
              <article class="overflow-hidden rounded-xl border border-border bg-card transition-colors hover:border-primary/30">
                <Image
                  src={project.data.coverImage}
                  alt={project.data.title}
                  width={600}
                  height={340}
                  class="aspect-video w-full object-cover"
                />
                <div class="p-4">
                  <h3 class="font-medium transition-colors group-hover:text-primary">
                    {project.data.title}
                  </h3>
                  <p class="mt-1 line-clamp-2 text-sm text-muted-foreground">
                    {project.data.summary}
                  </p>
                </div>
              </article>
            </a>
          ))}
        </div>
        <a
          href={`/${locale}/projects`}
          class="mt-6 inline-block text-sm font-medium text-primary hover:underline"
        >
          {t(locale, "projects.viewAll")}
        </a>
      </section>
    )
  }
</ContentLayout>
