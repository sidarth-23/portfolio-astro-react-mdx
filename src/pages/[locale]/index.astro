---
import ContentLayout from "@/layouts/content/content-layout.astro"
import Hero from "@/components/features/home/hero.astro"
import FeaturedListing from "@/components/features/home/featured-listing.astro"
import heroIllustration from "@/assets/images/hero-illustration.svg"
import BlogCard from "@/components/features/blog/blog-card.astro"
import {
  getPublishedBlogPosts,
  getFeaturedBlogPosts,
} from "@/lib/content/queries"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"
import { resolvePageSeo } from "@/lib/seo/resolve"
import { getPageSeo } from "@/lib/seo/pages"
import { getGlobalLink, homeCtaLinkIds } from "@/content/content"
import { SITE_URL } from "astro:env/server"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const featured = await getFeaturedBlogPosts(locale)
const heroPost = featured[0] ?? posts[0]
const gridPosts = posts.filter((post) => post.id !== heroPost?.id).slice(0, 4)
const primaryLink = getGlobalLink(homeCtaLinkIds.primary)
const secondaryLink = getGlobalLink(homeCtaLinkIds.secondary)

const siteUrl = SITE_URL
const pageSeo = getPageSeo("home", locale)
const seo = resolvePageSeo(
  pageSeo.title,
  pageSeo.description,
  `${siteUrl}/og/og-home-${locale}.png`,
  "website",
  locale,
  siteUrl,
  `/${locale}`,
  false
)
---

<ContentLayout seo={seo} locale={locale}>
  <Hero
    heading={t(locale, "hero.heading")}
    role={t(locale, "hero.role")}
    description={t(locale, "hero.description")}
    buttons={{
      primary: {
        text: t(locale, "hero.connect"),
        url: primaryLink.href(locale),
      },
      secondary: {
        text: t(locale, "hero.resume"),
        url: secondaryLink.href(locale),
        isExternal: secondaryLink.isExternal,
      },
    }}
  >
    <img
      slot="image"
      src={heroIllustration.src}
      alt={t(locale, "hero.imageAlt")}
      width={800}
      height={600}
      class="max-h-150 w-full rounded-md object-contain lg:max-h-200 dark:invert"
    />
  </Hero>

  {
    heroPost && (
      <FeaturedListing
        title={t(locale, "blog.latest")}
        viewAllHref={`/${locale}/blog`}
        viewAllText={t(locale, "blog.viewAll")}
      >
        <BlogCard
          slot="featured"
          variant="featured"
          post={heroPost}
          locale={locale}
        />
        {gridPosts.map((post) => (
          <BlogCard variant="compact" post={post} locale={locale} />
        ))}
      </FeaturedListing>
    )
  }
</ContentLayout>
