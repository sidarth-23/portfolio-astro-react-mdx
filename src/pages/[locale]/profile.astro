---
import ContentLayout from "@/layouts/content/ContentLayout.astro"
import ProfileContent from "@/components/features/profile/profile-content.astro"
import { defaultLocale, locales, type Locale } from "@/i18n/config"
import { getProfileByLocale, getProfileExperienceByLocale } from "@/lib/content/queries"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }
const entry =
  (await getProfileByLocale(locale)) ?? (await getProfileByLocale(defaultLocale))

if (!entry) {
  throw new Error(
    "Profile content is missing. Add files under src/content/profile/*.json"
  )
}

const experienceEntries =
  (await getProfileExperienceByLocale(locale)).length > 0
    ? await getProfileExperienceByLocale(locale)
    : await getProfileExperienceByLocale(defaultLocale)

const experiences = experienceEntries.map((item) => ({
  data: item.data,
}))
---

<ContentLayout title="Profile — Sidarth G" headerTitle="Profile" locale={locale}>
  <ProfileContent data={entry.data} experiences={experiences} />
</ContentLayout>
