---
import ContentLayout from "@/layouts/content/content-layout.astro"
import ProfileContent from "@/components/features/profile/profile-content.astro"
import { defaultLocale, locales, type Locale } from "@/i18n/config"
import { resolvePageSeo } from "@/lib/seo/resolve"
import { getPageSeo } from "@/lib/seo/pages"
import { getCollection, render } from "astro:content"
import { SITE_URL } from "astro:env/server"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }
const entries = await getCollection("profile")
const entry =
  entries.find((item) => item.id === locale) ??
  entries.find((item) => item.id === defaultLocale)!

const { Content } = await render(entry)

const siteUrl = SITE_URL
const pageSeo = getPageSeo("profile", locale)
const seo = resolvePageSeo(
  pageSeo.title,
  pageSeo.description,
  `${siteUrl}/og/og-profile-${locale}.png`,
  "website",
  locale,
  siteUrl,
  `/${locale}/profile`
)
---

<ContentLayout seo={seo} headerTitle="Profile" locale={locale}>
  <ProfileContent data={entry.data}>
    <Content />
  </ProfileContent>
</ContentLayout>
