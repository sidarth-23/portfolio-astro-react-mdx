---
import BlogPostLayout from "@/layouts/content/BlogPostLayout.astro"
import TableOfContents from "@/layouts/toc/table-of-contents.astro"
import MobileToc from "@/layouts/toc/mobile-toc.astro"
import TocScrollspy from "@/layouts/toc/toc-scrollspy.astro"
import { Badge } from "@/components/ui/astro/badge"
import BlurBackdropImage from "@/components/providers/blur-backdrop-image.astro"
import { getPublishedBlogPosts } from "@/lib/content/queries"
import { formatDate, estimateReadingTime } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"
import { render } from "astro:content"
import type { CollectionEntry } from "astro:content"
import CodeGroup from "@/components/mdx/CodeGroup.astro"

export async function getStaticPaths() {
  const paths: Array<{
    params: { locale: Locale; slug: string }
    props: { post: CollectionEntry<"blog"> }
  }> = []

  for (const locale of locales) {
    const posts = await getPublishedBlogPosts(locale)
    for (const post of posts) {
      const slug = post.id.split("/").slice(1).join("/")
      paths.push({
        params: { locale, slug },
        props: { post },
      })
    }
  }

  return paths
}

interface Props {
  post: CollectionEntry<"blog">
}

const { post } = Astro.props
const { locale } = Astro.params as { locale: Locale }
const { Content, headings } = await render(post)

const pubDate = formatDate(post.data.date, locale)
const updatedDate = post.data.updatedDate
  ? formatDate(post.data.updatedDate, locale)
  : null
const showUpdatedDate = updatedDate && updatedDate !== pubDate
const readingTime = estimateReadingTime(post.body ?? "")
---

<BlogPostLayout post={post} locale={locale}>
  <MobileToc slot="mobile-toc" items={headings} onThisPageLabel={t(locale, "toc.onThisPage")} />
  <TocScrollspy />

  <article class="max-w-none">
    <header class="mb-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div
          class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted-foreground"
        >
          <time datetime={post.data.date.toISOString()}>
            {t(locale, "blog.published")}: {pubDate}
          </time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} {t(locale, "blog.minRead")}</span>
          {
            showUpdatedDate && (
              <>
                <span aria-hidden="true">·</span>
                <time datetime={post.data.updatedDate?.toISOString()}>
                  {t(locale, "blog.updated")} {updatedDate}
                </time>
              </>
            )
          }
        </div>
        {
          post.data.category && (
            <Badge variant="default" class="shrink-0 capitalize">
              {post.data.category}
            </Badge>
          )
        }
      </div>

      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        {post.data.title}
      </h1>
      <p class="mt-3 text-lg text-muted-foreground">{post.data.description}</p>

      {
        post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <Badge variant="outline" class="text-muted-foreground/80">
                #{tag}
              </Badge>
            ))}
          </div>
        )
      }
    </header>

    <BlurBackdropImage
      src={post.data.coverImage}
      alt={post.data.title}
      width={post.data.coverImage.width}
      height={post.data.coverImage.height}
      format="webp"
      class="mb-10 aspect-video w-full rounded-xl bg-muted/30"
    />

    <div class="prose prose-lg max-w-none prose-zinc dark:prose-invert">
      <Content components={{ CodeGroup }} />
    </div>
  </article>

  <TableOfContents slot="toc" items={headings} onThisPageLabel={t(locale, "toc.onThisPage")} />
</BlogPostLayout>
