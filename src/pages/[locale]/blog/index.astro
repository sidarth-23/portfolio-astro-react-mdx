---
import ContentLayout from "@/layouts/ContentLayout.astro"
import { getPublishedBlogPosts, getAllTags, formatShortDate } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const tags = getAllTags(posts)
---

<ContentLayout title={t(locale, "blog.title") + " — Sid"} locale={locale}>
  <h1 class="text-3xl font-bold tracking-tight mb-2">{t(locale, "blog.title")}</h1>
  <p class="text-muted-foreground mb-8">{t(locale, "blog.description")}</p>

  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <div class="flex flex-col gap-8">
    {
      posts.map((post) => (
        <a href={`/${locale}/blog/${post.slug.split("/").slice(1).join("/")}`} class="group block">
          <article class="flex flex-col gap-2 border-b border-border/50 pb-8 last:border-0">
            <time class="text-xs text-muted-foreground/70">{formatShortDate(post.data.date, locale)}</time>
            <h2 class="text-xl font-medium group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-muted-foreground line-clamp-2">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-1 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="text-xs text-muted-foreground/80">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        </a>
      ))
    }
  </div>
</ContentLayout>
