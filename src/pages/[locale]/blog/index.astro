---
import ContentLayout from "@/layouts/ContentLayout.astro"
import BlogCard from "@/components/blog/blog-card.astro"
import { Badge } from "@/components/ui/badge"
import { getPublishedBlogPosts, getAllTags } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const posts = await getPublishedBlogPosts(locale)
const tags = getAllTags(posts)
---

<ContentLayout title={t(locale, "blog.title") + " — Sid"} locale={locale}>
  <h1 class="text-3xl font-bold tracking-tight mb-2">{t(locale, "blog.title")}</h1>
  <p class="text-muted-foreground mb-8">{t(locale, "blog.description")}</p>

  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <Badge variant="outline" className="text-muted-foreground/80">#{tag}</Badge>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      posts.map((post) => (
        <BlogCard post={post} locale={locale} />
      ))
    }
  </div>
</ContentLayout>
