---
export const prerender = false

import ContentLayout from "@/layouts/content/ContentLayout.astro"
import { BlogListWithProvider } from "@/components/providers/blog-list"
import { getBlogListing, getBlogFilters } from "@/lib/api/listing-api"
import type { Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"
import { resolvePageSeo } from "@/lib/seo/resolve"
import { getPageSeo } from "@/lib/seo/pages"

const { locale } = Astro.params as { locale: Locale }
const url = Astro.url

const search = url.searchParams.get("search") ?? ""
const tagsParam = url.searchParams.get("tags")
const categoriesParam = url.searchParams.get("categories")
const sort = url.searchParams.get("sort")

const tags = tagsParam ? tagsParam.split(",") : []
const categories = categoriesParam ? categoriesParam.split(",") : []
const sortMode = sort && ["newest", "oldest", "title"].includes(sort)
  ? sort as "newest" | "oldest" | "title"
  : null

const [initialData, availableFilters] = await Promise.all([
  getBlogListing(locale, {
    search: search || undefined,
    tags: tags.length > 0 ? tags : undefined,
    categories: categories.length > 0 ? categories : undefined,
    sort: sortMode || undefined,
    page: 1,
    limit: 12,
  }),
  getBlogFilters(locale),
])

const siteUrl = Astro.site?.toString() ?? "https://sidshub.in"
const pageSeo = getPageSeo("blog", locale)
const seo = resolvePageSeo(
  pageSeo.title,
  pageSeo.description,
  `${siteUrl}/og/blog-${locale}.png`,
  "website",
  locale,
  siteUrl,
  `/${locale}/blog`
)
---

<ContentLayout seo={seo} locale={locale}>
  <h1 class="text-3xl font-bold tracking-tight mb-2">
    {t(locale, "blog.title")}
  </h1>
  <p class="text-muted-foreground mb-8">{t(locale, "blog.description")}</p>

  <BlogListWithProvider
    client:load
    locale={locale}
    tags={availableFilters.tags}
    categories={availableFilters.categories}
    initialSearch={search}
    initialTags={tags}
    initialCategories={categories}
    initialSortBy={sortMode}
    initialData={initialData}
  />
</ContentLayout>
