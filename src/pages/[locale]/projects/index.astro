---
import ContentLayout from "@/layouts/ContentLayout.astro"
import ProjectCard from "@/components/project/project-card.astro"
import { Badge } from "@/components/ui/badge"
import { getAllProjects, getAllProjectTags } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const projects = await getAllProjects(locale)
const tags = getAllProjectTags(projects)
---

<ContentLayout title={t(locale, "projects.title") + " — Sid"} locale={locale}>
  <h1 class="mb-2 text-3xl font-bold tracking-tight">
    {t(locale, "projects.title")}
  </h1>
  <p class="mb-8 text-muted-foreground">{t(locale, "projects.description")}</p>

  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <Badge variant="secondary">#{tag}</Badge>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project) => (
        <ProjectCard project={project} locale={locale} />
      ))
    }
  </div>
</ContentLayout>
