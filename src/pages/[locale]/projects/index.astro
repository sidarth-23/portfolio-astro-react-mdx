---
export const prerender = false

import ContentLayout from "@/layouts/content/content-layout.astro"
import { ProjectListWithProvider } from "@/components/providers/project-list"
import { getProjectListing, getProjectFilters } from "@/lib/api/listing-api"
import { parseListingFilters, toListingFilters } from "@/lib/api/listing-query"
import type { Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"
import { resolvePageSeo } from "@/lib/seo/resolve"
import { getPageSeo } from "@/lib/seo/pages"
import { SITE_URL } from "astro:env/server"

const { locale } = Astro.params as { locale: Locale }
const filters = parseListingFilters(Astro.url.searchParams)

const [initialData, availableFilters] = await Promise.all([
  getProjectListing(locale, {
    ...toListingFilters(filters),
    page: 1,
    limit: 12,
  }),
  getProjectFilters(locale),
])

const siteUrl = SITE_URL
const pageSeo = getPageSeo("projects", locale)
const seo = resolvePageSeo(
  pageSeo.title,
  pageSeo.description,
  `${siteUrl}/og/og-projects-${locale}.png`,
  "website",
  locale,
  siteUrl,
  `/${locale}/projects`
)
---

<ContentLayout seo={seo} locale={locale}>
  <h1 class="mb-2 text-3xl font-bold tracking-tight">
    {t(locale, "projects.title")}
  </h1>
  <p class="mb-8 text-muted-foreground">{t(locale, "projects.description")}</p>

  <ProjectListWithProvider
    client:load
    locale={locale}
    tags={availableFilters.tags}
    categories={availableFilters.categories}
    initialSearch={filters.search}
    initialTags={filters.tags}
    initialCategories={filters.categories}
    initialSortBy={filters.sort}
    initialData={initialData}
  />
</ContentLayout>
