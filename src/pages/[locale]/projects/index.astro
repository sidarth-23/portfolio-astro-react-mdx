---
import ContentLayout from "@/layouts/ContentLayout.astro"
import { Image } from "astro:assets"
import { getAllProjects, getAllProjectTags, formatShortDate } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }

const projects = await getAllProjects(locale)
const tags = getAllProjectTags(projects)
---

<ContentLayout title={t(locale, "projects.title") + " — Sid"} locale={locale}>
  <h1 class="text-3xl font-bold tracking-tight mb-2">{t(locale, "projects.title")}</h1>
  <p class="text-muted-foreground mb-8">{t(locale, "projects.description")}</p>

  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {
      projects.map((project) => (
        <a href={`/${locale}/projects/${project.slug.split("/").slice(1).join("/")}`} class="group block">
          <article class="overflow-hidden rounded-xl border border-border bg-card transition-colors hover:border-primary/30 h-full flex flex-col">
            <Image
              src={project.data.coverImage}
              alt={project.data.title}
              width={600}
              height={340}
              class="aspect-video w-full object-cover"
            />
            <div class="flex flex-1 flex-col p-5">
              <div class="flex items-center justify-between gap-2">
                <h2 class="font-medium group-hover:text-primary transition-colors">
                  {project.data.title}
                </h2>
                {project.data.featured && (
                  <span class="inline-flex items-center rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-primary">
                    {t(locale, "projects.featuredLabel")}
                  </span>
                )}
              </div>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2 flex-1">
                {project.data.summary}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {project.data.tags.map((tag) => (
                  <span class="text-xs text-muted-foreground/80">#{tag}</span>
                ))}
              </div>
              <time class="mt-3 text-xs text-muted-foreground/60">
                {formatShortDate(project.data.date, locale)}
              </time>
            </div>
          </article>
        </a>
      ))
    }
  </div>
</ContentLayout>
