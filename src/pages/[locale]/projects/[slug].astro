---
import ProjectLayout from "@/layouts/content/ProjectLayout.astro"
import TableOfContents from "@/layouts/toc/table-of-contents.astro"
import MobileToc from "@/layouts/toc/mobile-toc.astro"
import TocScrollspy from "@/layouts/toc/toc-scrollspy.astro"
import { ProjectLinkButtons } from "@/components/features/projects/project-link-buttons"
import { Badge } from "@/components/ui/astro/badge"
import BlurBackdropImage from "@/components/providers/blur-backdrop-image.astro"
import { getAllProjects } from "@/lib/content/queries"
import { formatDate, estimateReadingTime } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import { t } from "@/i18n/ui"
import { render } from "astro:content"
import type { CollectionEntry } from "astro:content"
import CodeGroup from "@/components/mdx/CodeGroup.astro"

export async function getStaticPaths() {
  const paths: Array<{
    params: { locale: Locale; slug: string }
    props: { project: CollectionEntry<"projects"> }
  }> = []

  for (const locale of locales) {
    const projects = await getAllProjects(locale)
    for (const project of projects) {
      const slug = project.id.split("/").slice(1).join("/")
      paths.push({
        params: { locale, slug },
        props: { project },
      })
    }
  }

  return paths
}

interface Props {
  project: CollectionEntry<"projects">
}

const { project } = Astro.props
const { locale } = Astro.params as { locale: Locale }
const { Content, headings } = await render(project)

const date = formatDate(project.data.date, locale)
const updatedDate = project.data.updatedDate
  ? formatDate(project.data.updatedDate, locale)
  : null
const showUpdatedDate = updatedDate && updatedDate !== date
const readingTime = estimateReadingTime(project.body ?? "")
---

<ProjectLayout project={project} locale={locale}>
  <MobileToc slot="mobile-toc" items={headings} onThisPageLabel={t(locale, "toc.onThisPage")} />
  <TocScrollspy />

  <article class="max-w-none">
    <header class="mb-8">
      <div
        class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted-foreground"
      >
        <time datetime={project.data.date.toISOString()}>
          {t(locale, "projects.published")}: {date}
        </time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} {t(locale, "projects.minRead")}</span>
        {
          showUpdatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <time datetime={project.data.updatedDate?.toISOString()}>
                {t(locale, "projects.updated")} {updatedDate}
              </time>
            </>
          )
        }
      </div>

      <div class="mt-3 flex items-center gap-3">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          {project.data.title}
        </h1>
        {
          project.data.status !== "active" && (
            <Badge variant="secondary" class="capitalize">
              {project.data.status}
            </Badge>
          )
        }
      </div>

      <p class="mt-3 text-lg text-muted-foreground">{project.data.summary}</p>

      {
        project.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag) => (
              <Badge variant="secondary">#{tag}</Badge>
            ))}
          </div>
        )
      }

      {
        project.data.links.length > 0 && (
          <div class="mt-4">
            <ProjectLinkButtons links={project.data.links} />
          </div>
        )
      }
    </header>

    <BlurBackdropImage
      src={project.data.coverImage}
      alt={project.data.title}
      width={1280}
      height={720}
      fit="contain"
      format="webp"
      class="mb-10 aspect-video w-full rounded-xl bg-muted/30"
    />

    <div class="prose prose-lg max-w-none prose-zinc dark:prose-invert">
      <Content components={{ CodeGroup }} />
    </div>
  </article>

  <TableOfContents slot="toc" items={headings} onThisPageLabel={t(locale, "toc.onThisPage")} />
</ProjectLayout>
