---
import ProjectLayout from "@/layouts/ProjectLayout.astro"
import TableOfContents from "@/components/toc/table-of-contents.astro"
import MobileToc from "@/components/toc/mobile-toc.astro"
import TocScrollspy from "@/components/toc/toc-scrollspy.astro"
import { ProjectLinkButtons } from "@/components/project/project-link-buttons"
import { Badge } from "@/components/ui/badge"
import { Image } from "astro:assets"
import { getAllProjects, formatDate, estimateReadingTime } from "@/lib/content"
import { locales, type Locale } from "@/i18n/config"
import type { CollectionEntry } from "astro:content"

export async function getStaticPaths() {
  const paths: Array<{ params: { locale: Locale; slug: string }; props: { project: CollectionEntry<"projects"> } }> = []

  for (const locale of locales) {
    const projects = await getAllProjects(locale)
    for (const project of projects) {
      const slug = project.slug.split("/").slice(1).join("/")
      paths.push({
        params: { locale, slug },
        props: { project },
      })
    }
  }

  return paths
}

interface Props {
  project: CollectionEntry<"projects">
}

const { project } = Astro.props
const { locale } = Astro.params as { locale: Locale }
const { Content, headings } = await project.render()

const date = formatDate(project.data.date, locale)
const updatedDate = project.data.updatedDate ? formatDate(project.data.updatedDate, locale) : null
const showUpdatedDate = updatedDate && updatedDate !== date
const readingTime = estimateReadingTime(project.body)
---

<ProjectLayout project={project} locale={locale}>
  <MobileToc slot="mobile-toc" items={headings} />
  <TocScrollspy />

  <article class="max-w-none">
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted-foreground">
        <time datetime={project.data.date.toISOString()}>{date}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {
          showUpdatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <time datetime={project.data.updatedDate?.toISOString()}>{updatedDate}</time>
            </>
          )
        }
      </div>

      <div class="mt-3 flex items-center gap-3">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{project.data.title}</h1>
        {
          project.data.status !== "active" && (
            <Badge variant="default" className="capitalize">
              {project.data.status}
            </Badge>
          )
        }
      </div>

      <p class="mt-3 text-lg text-muted-foreground">{project.data.summary}</p>

      {
        project.data.links.length > 0 && (
          <div class="mt-4">
            <ProjectLinkButtons links={project.data.links} />
          </div>
        )
      }

      {
        project.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.data.tags.map((tag) => (
              <Badge variant="outline" className="text-muted-foreground/80">#{tag}</Badge>
            ))}
          </div>
        )
      }
    </header>

    <Image
      src={project.data.coverImage}
      alt={project.data.title}
      width={1200}
      height={630}
      class="mb-10 w-full rounded-xl object-cover"
    />

    <div class="prose prose-lg prose-zinc max-w-none dark:prose-invert">
      <Content />
    </div>
  </article>

  <TableOfContents slot="toc" items={headings} />
</ProjectLayout>
