---
import ContentLayout from "@/layouts/ContentLayout.astro"
import CvContent from "@/components/sections/cv-content.astro"
import { defaultLocale, locales, type Locale } from "@/i18n/config"
import { getCvByLocale, getCvExperienceByLocale } from "@/lib/content"

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }))
}

const { locale } = Astro.params as { locale: Locale }
const entry =
  (await getCvByLocale(locale)) ?? (await getCvByLocale(defaultLocale))

if (!entry) {
  throw new Error(
    "CV content is missing. Add files under src/content/cv/*.json"
  )
}

const experienceEntries =
  (await getCvExperienceByLocale(locale)).length > 0
    ? await getCvExperienceByLocale(locale)
    : await getCvExperienceByLocale(defaultLocale)

const experiences = await Promise.all(
  experienceEntries.map(async (item) => {
    const { Content } = await item.render()
    return {
      data: item.data,
      Content,
    }
  })
)
---

<ContentLayout title="CV — Sidarth G" headerTitle="CV" locale={locale}>
  <CvContent data={entry.data} experiences={experiences} />
</ContentLayout>
