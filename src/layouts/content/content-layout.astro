---
import Layout from "@/layouts/base/layout.astro"
import type { Locale } from "@/i18n/config"
import type { SeoData } from "@/lib/seo/resolve"

interface Props {
  seo: SeoData
  headerTitle?: string
  locale?: Locale
  noTopPadding?: boolean
}

const { seo, headerTitle, locale = "en", noTopPadding = false } = Astro.props
const hasToc = Astro.slots.has("toc")
---

<Layout seo={seo} headerTitle={headerTitle} locale={locale}>
  {Astro.slots.has("mobile-toc") && <slot name="mobile-toc" />}
  <div
    class:list={[
      "mx-auto w-full max-w-7xl flex-1 px-6 pb-12",
      noTopPadding ? "pt-0" : "pt-12",
    ]}
    transition:animate="fade"
  >
    <div
      class={hasToc ? "grid grid-cols-1 gap-12 xl:grid-cols-[1fr_280px]" : ""}
    >
      <div>
        <slot />
      </div>
      {hasToc && <slot name="toc" />}
    </div>
  </div>
</Layout>
