---
import ContentLayout from "@/layouts/content/ContentLayout.astro"
import type { CollectionEntry } from "astro:content"
import type { Locale } from "@/i18n/config"
import { resolveContentSeo } from "@/lib/seo/resolve"

interface Props {
  project: CollectionEntry<"projects">
  locale?: Locale
}

const { project, locale = "en" } = Astro.props

const siteUrl = Astro.site?.toString() ?? "https://sidshub.in"
const seo = resolveContentSeo(project, "projects", locale, siteUrl)
---

<ContentLayout
  seo={seo}
  headerTitle={project.data.title}
  locale={locale}
>
  <slot />
  <slot name="toc" slot="toc" />
  <slot name="mobile-toc" slot="mobile-toc" />
</ContentLayout>
