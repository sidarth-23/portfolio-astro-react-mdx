---
import ContentLayout from "@/layouts/content/ContentLayout.astro"
import type { CollectionEntry } from "astro:content"
import type { Locale } from "@/i18n/config"
import { resolveContentSeo } from "@/lib/seo/resolve"

interface Props {
  post: CollectionEntry<"blog">
  locale?: Locale
}

const { post, locale = "en" } = Astro.props

const siteUrl = Astro.site?.toString() ?? "https://sidshub.in"
const seo = resolveContentSeo(post, "blog", locale, siteUrl)
---

<ContentLayout seo={seo} headerTitle={post.data.title} locale={locale}>
  <slot />
  <slot name="toc" slot="toc" />
  <slot name="mobile-toc" slot="mobile-toc" />
</ContentLayout>
