---
import { HugeiconsIcon } from "@hugeicons/react"
import { ArrowDown01Icon } from "@hugeicons/core-free-icons"
import { CircularProgress } from "@/components/ui/react/circular-progress"

export interface TocItem {
  depth: number
  slug: string
  text: string
}

type Props = {
  items: TocItem[]
  onThisPageLabel?: string
}

const { items } = Astro.props
const tocItems = items.filter((item) => item.depth === 2 || item.depth === 3)
const firstItem = tocItems[0]
---

{
  tocItems.length > 0 && (
    <details data-toc="mobile" class="group xl:hidden sticky top-0 z-50 bg-background border-b border-border">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-2 px-6 py-3 text-sm font-semibold text-muted-foreground">
        <div class="flex min-w-0 flex-1 items-center gap-2.5">
          <CircularProgress
            value={0}
            min={0}
            max={1}
            size={18}
            strokeWidth={1.5}
            indicatorDataAttribute="data-toc-progress-value"
            aria-hidden="true"
          />
          <span data-toc-summary class="truncate">
            {firstItem?.text ?? ""}
          </span>
        </div>
        <HugeiconsIcon
          icon={ArrowDown01Icon}
          size={16}
          strokeWidth={2}
          className="size-4 shrink-0 transition-transform group-open:rotate-180"
          aria-hidden="true"
        />
      </summary>
      <nav aria-label="Table of contents" class="absolute left-0 right-0 bg-background border-b border-border shadow-lg px-6 pb-3">
        <div data-toc-scroll-container class="max-h-[60vh] overflow-y-auto">
          <ul class="flex flex-col">
            {tocItems.map((item) => {
              const indentClass = item.depth === 2 ? "pl-3" : "pl-8"
              return (
                <li>
                  <a
                    data-toc-link
                    href={`#${item.slug}`}
                    class={`block border-l-[1.5px] border-border/35 py-1.5 text-[0.85rem] leading-snug text-muted-foreground/80 transition-colors hover:border-border hover:text-foreground ${indentClass}`}
                  >
                    {item.text}
                  </a>
                </li>
              )
            })}
          </ul>
        </div>
      </nav>
    </details>

    <style>
      summary::-webkit-details-marker {
        display: none;
      }
    </style>
  )
}
