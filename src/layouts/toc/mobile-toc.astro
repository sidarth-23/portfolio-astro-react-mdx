---
export interface TocItem {
  depth: number
  slug: string
  text: string
}

type Props = {
  items: TocItem[]
}

const { items } = Astro.props
const tocItems = items.filter((item) => item.depth === 2 || item.depth === 3)
const firstItem = tocItems[0]
---

{
  tocItems.length > 0 && (
    <details data-toc="mobile" class="group xl:hidden sticky top-0 z-50 bg-background border-b border-border">
      <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-3 text-sm font-semibold text-muted-foreground">
        <span data-toc-summary>
          On this page · {firstItem?.text ?? ""}
        </span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4 transition-transform group-open:rotate-180"
          aria-hidden="true"
        >
          <path d="m6 9 6 6 6-6" />
        </svg>
      </summary>
      <nav aria-label="Table of contents" class="absolute left-0 right-0 bg-background border-b border-border shadow-lg px-6 pb-3">
        <div class="max-h-[60vh] overflow-y-auto">
          <ul class="flex flex-col">
            {tocItems.map((item) => {
              const indentClass = item.depth === 2 ? "pl-3" : "pl-8"
              return (
                <li>
                  <a
                    data-toc-link
                    href={`#${item.slug}`}
                    class={`block border-l-[1.5px] border-transparent py-1.5 text-[0.85rem] leading-snug text-muted-foreground/80 transition-colors hover:border-border hover:text-foreground ${indentClass}`}
                  >
                    {item.text}
                  </a>
                </li>
              )
            })}
          </ul>
        </div>
      </nav>
    </details>

    <style>
      summary::-webkit-details-marker {
        display: none;
      }
    </style>
  )
}
