---
export interface TocItem {
  depth: number
  slug: string
  text: string
}

type Props = {
  items: TocItem[]
  onThisPageLabel?: string
}

const { items }: Props = Astro.props
const tocItems = items.filter((item) => item.depth === 2 || item.depth === 3)
const onThisPageLabel = Astro.props.onThisPageLabel ?? "On this page"
---

{
  tocItems.length > 0 && (
    <nav data-toc="desktop" aria-label="Table of contents" class="hidden xl:block">
      <div data-toc-scroll-container class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pb-4">
        <div class="mb-3 border-b border-border pb-2 text-sm font-semibold text-muted-foreground">
          {onThisPageLabel}
        </div>
        <ul class="flex flex-col">
          {tocItems.map((item) => {
            const indentClass = item.depth === 2 ? "pl-3" : "pl-8"
            return (
              <li>
                <a
                  data-toc-link
                  href={`#${item.slug}`}
                  class={`block border-l-[1.5px] border-border/35 py-1.5 text-[0.85rem] leading-snug text-muted-foreground/80 transition-colors hover:border-border hover:text-foreground ${indentClass}`}
                >
                  {item.text}
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    </nav>
  )
}
