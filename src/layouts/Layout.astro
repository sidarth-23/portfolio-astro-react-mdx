---
import "@/styles/global.css"
import { resolveSeo } from "@/lib/content/seo"
import { AppShell } from "@/components/layout/app-shell"
import avatarImage from "@/assets/images/avatar.jpg"
import { ClientRouter } from "astro:transitions"
import type { Locale } from "@/i18n/config"

interface Props {
  title: string
  description?: string
  image?: string
  seo?: import("@/lib/content/seo").SeoData
  headerTitle?: string
  locale?: Locale
}

const {
  title,
  description = "Sid's portfolio — thoughts on engineering, design, and building things.",
  image = "/og-default.jpg",
  seo,
  headerTitle,
  locale = "en",
} = Astro.props

const resolved = resolveSeo({ title, description, image }, seo)
const canonical = new URL(Astro.url.pathname, Astro.site)
const currentPath = Astro.url.pathname
const avatarSrc = avatarImage.src
---

<html lang={locale} transition:animate="none">
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{resolved.title}</title>
    <meta name="description" content={resolved.description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={resolved.ogTitle} />
    <meta property="og:description" content={resolved.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {
      resolved.ogImage && (
        <meta property="og:image" content={resolved.ogImage} />
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content={resolved.twitterCard} />
    <meta name="twitter:title" content={resolved.ogTitle} />
    <meta name="twitter:description" content={resolved.ogDescription} />
    {
      resolved.ogImage && (
        <meta name="twitter:image" content={resolved.ogImage} />
      )
    }

    <!-- Theme initialization script -->
    <script is:inline data-astro-rerun>
      (function() {
        const theme = localStorage.getItem('theme') || 'system'
        const root = document.documentElement
        let targetTheme
        if (theme === 'system') {
          targetTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        } else {
          targetTheme = theme
        }
        root.classList.remove('light', 'dark')
        root.classList.add(targetTheme)
      })()
    </script>

    <!-- Prevent theme flash during view transitions -->
    <script>
      document.addEventListener('astro:before-swap', (e) => {
        const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light'
        e.newDocument.documentElement.classList.remove('light', 'dark')
        e.newDocument.documentElement.classList.add(currentTheme)
      })
    </script>

    <!-- Code block copy buttons -->
    <script is:inline data-astro-rerun>
      (function initCodeBlocks() {
        function wrapCodeBlock(pre) {
          // Skip if already wrapped
          if (pre.closest('.code-block-wrapper')) return
          // Skip if inside CodeGroup
          if (pre.closest('[data-code-group]')) return

          const filename = pre.getAttribute('data-filename')
          const wrapper = document.createElement('div')
          wrapper.className = 'code-block-wrapper'
          if (!filename) {
            wrapper.setAttribute('data-has-filename', 'false')
          }

          const header = document.createElement('div')
          header.className = 'code-block-header'

          // Filename
          if (filename) {
            const filenameEl = document.createElement('span')
            filenameEl.className = 'code-block-filename'
            filenameEl.textContent = filename
            header.appendChild(filenameEl)
          }

          // Copy button with shadcn Button styling
          const copyBtn = document.createElement('button')
          copyBtn.type = 'button'
          copyBtn.className = 'code-block-copy'
          copyBtn.setAttribute('aria-label', 'Copy code')
          copyBtn.innerHTML = `
            <svg data-icon="copy" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            <svg data-icon="check" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"></polyline></svg>
          `

          copyBtn.addEventListener('click', () => {
            const code = pre.querySelector('code')?.textContent || ''
            navigator.clipboard.writeText(code).then(() => {
              const copyIcon = copyBtn.querySelector('[data-icon="copy"]')
              const checkIcon = copyBtn.querySelector('[data-icon="check"]')
              if (copyIcon) copyIcon.style.display = 'none'
              if (checkIcon) checkIcon.style.display = 'block'
              setTimeout(() => {
                if (copyIcon) copyIcon.style.display = 'block'
                if (checkIcon) checkIcon.style.display = 'none'
              }, 2000)
            })
          })

          header.appendChild(copyBtn)

          // Wrap the pre
          pre.parentNode.insertBefore(wrapper, pre)
          wrapper.appendChild(header)
          wrapper.appendChild(pre)
        }

        // Process all pre elements
        document.querySelectorAll('pre').forEach(wrapCodeBlock)
      })()
    </script>
  </head>
  <body class="min-h-svh bg-background text-foreground antialiased">
    <AppShell client:load currentPath={currentPath} avatarSrc={avatarSrc} pageTitle={headerTitle} locale={locale}>
      <slot />
    </AppShell>
  </body>
</html>
