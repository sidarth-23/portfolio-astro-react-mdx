---
import BaseLayout from "@/layouts/base/base-layout.astro"
import { AppShell } from "@/layouts/shell/app-shell"
import avatarImage from "@/assets/images/avatar.jpg"
import { getImage } from "astro:assets"
import type { Locale } from "@/i18n/config"
import type { SeoData } from "@/lib/seo/resolve"

interface Props {
  seo: SeoData
  headerTitle?: string
  locale?: Locale
}

const { seo, headerTitle, locale = "en" } = Astro.props

const currentPath = Astro.url.pathname
const [avatarSm, avatarLg] = await Promise.all([
  getImage({
    src: avatarImage,
    width: 80,
    height: 80,
    format: "webp",
    quality: 80,
  }),
  getImage({
    src: avatarImage,
    width: 160,
    height: 160,
    format: "webp",
    quality: 80,
  }),
])
const avatarSrc = avatarSm.src
const avatarSrcSet = `${avatarSm.src} 1x, ${avatarLg.src} 2x`
---

<BaseLayout
  locale={locale}
  seo={seo}
  bodyClass="min-h-svh bg-background text-foreground antialiased"
>
  <AppShell
    client:load
    currentPath={currentPath}
    avatarSrc={avatarSrc}
    avatarSrcSet={avatarSrcSet}
    pageTitle={headerTitle}
    locale={locale}
  >
    <slot />
  </AppShell>
</BaseLayout>
