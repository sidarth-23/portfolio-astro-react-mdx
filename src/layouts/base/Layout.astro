---
import { resolveSeo } from "@/lib/content/seo"
import BaseLayout from "@/layouts/base/BaseLayout.astro"
import { AppShell } from "@/layouts/shell/app-shell"
import avatarImage from "@/assets/images/avatar.jpg"
import { getImage } from "astro:assets"
import type { Locale } from "@/i18n/config"

interface Props {
  title: string
  description?: string
  image?: string
  seo?: import("@/lib/content/seo").SeoData
  headerTitle?: string
  locale?: Locale
}

const {
  title,
  description = "Sid's portfolio — thoughts on engineering, design, and building things.",
  image = "/og-default.jpg",
  seo,
  headerTitle,
  locale = "en",
} = Astro.props

const resolved = resolveSeo({ title, description, image }, seo)
const canonical = new URL(Astro.url.pathname, Astro.site)
const currentPath = Astro.url.pathname
const [avatarSm, avatarLg] = await Promise.all([
  getImage({
    src: avatarImage,
    width: 80,
    height: 80,
    format: "webp",
    quality: 80,
  }),
  getImage({
    src: avatarImage,
    width: 160,
    height: 160,
    format: "webp",
    quality: 80,
  }),
])
const avatarSrc = avatarSm.src
const avatarSrcSet = `${avatarSm.src} 1x, ${avatarLg.src} 2x`
---

<BaseLayout
  locale={locale}
  title={resolved.title}
  description={resolved.description}
  bodyClass="min-h-svh bg-background text-foreground antialiased"
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={resolved.ogTitle} />
    <meta property="og:description" content={resolved.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {resolved.ogImage && <meta property="og:image" content={resolved.ogImage} />}
    <meta name="twitter:card" content={resolved.twitterCard} />
    <meta name="twitter:title" content={resolved.ogTitle} />
    <meta name="twitter:description" content={resolved.ogDescription} />
    {resolved.ogImage && <meta name="twitter:image" content={resolved.ogImage} />}
  </Fragment>

  <AppShell
    client:load
    currentPath={currentPath}
    avatarSrc={avatarSrc}
    avatarSrcSet={avatarSrcSet}
    pageTitle={headerTitle}
    locale={locale}
  >
    <slot />
  </AppShell>
</BaseLayout>
