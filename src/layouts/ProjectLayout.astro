---
import ContentLayout from "@/layouts/ContentLayout.astro"
import type { CollectionEntry } from "astro:content"
import type { Locale } from "@/i18n/config"

interface Props {
  project: CollectionEntry<"projects">
  locale?: Locale
}

const { project, locale = "en" } = Astro.props
---

<ContentLayout
  title={project.data.seo?.title ?? project.data.title}
  description={project.data.seo?.description ?? project.data.summary}
  image={project.data.seo?.image}
  seo={project.data.seo}
  headerTitle={project.data.title}
  locale={locale}
>
  <slot />
  <slot name="toc" slot="toc" />
  <slot name="mobile-toc" slot="mobile-toc" />
</ContentLayout>
