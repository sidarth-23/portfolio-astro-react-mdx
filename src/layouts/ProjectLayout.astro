---
import ContentLayout from "./ContentLayout.astro"
import type { CollectionEntry } from "astro:content"

interface Props {
  project: CollectionEntry<"projects">
}

const { project } = Astro.props
---

<ContentLayout
  title={project.data.seo?.title ?? project.data.title}
  description={project.data.seo?.description ?? project.data.summary}
  image={project.data.seo?.image}
  seo={project.data.seo}
  headerTitle={project.data.title}
>
  <slot />
</ContentLayout>
