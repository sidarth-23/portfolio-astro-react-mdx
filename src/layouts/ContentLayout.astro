---
import Layout from "./Layout.astro"
import type { Locale } from "@/i18n/config"

interface Props {
  title: string
  description?: string
  image?: string
  seo?: import("@/lib/seo").SeoData
  headerTitle?: string
  locale?: Locale
}

const props = Astro.props
---

<Layout {...props}>
  <div
    class="mx-auto w-full max-w-7xl flex-1 px-6 py-12"
    transition:animate="fade"
  >
    <slot />
  </div>
</Layout>
