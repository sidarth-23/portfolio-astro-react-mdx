---
import Layout from "./Layout.astro"
import type { Locale } from "@/i18n/config"

interface Props {
  title: string
  description?: string
  image?: string
  seo?: import("@/lib/seo").SeoData
  headerTitle?: string
  locale?: Locale
}

const props = Astro.props
const hasToc = Astro.slots.has("toc")
---

<Layout {...props}>
  {Astro.slots.has("mobile-toc") && <slot name="mobile-toc" />}
  <div
    class="mx-auto w-full max-w-7xl flex-1 px-6 py-12"
    transition:animate="fade"
  >
    <div class={hasToc ? "grid grid-cols-1 gap-12 xl:grid-cols-[1fr_280px]" : ""}>
      <div>
        <slot />
      </div>
      {hasToc && <slot name="toc" />}
    </div>
  </div>
</Layout>
