---
import ContentLayout from "./ContentLayout.astro"
import type { CollectionEntry } from "astro:content"
import type { Locale } from "@/i18n/config"

interface Props {
  post: CollectionEntry<"blog">
  locale?: Locale
}

const { post, locale = "en" } = Astro.props
---

<ContentLayout
  title={post.data.seo?.title ?? post.data.title}
  description={post.data.seo?.description ?? post.data.description}
  image={post.data.seo?.image}
  seo={post.data.seo}
  headerTitle={post.data.title}
  locale={locale}
>
  <slot />
</ContentLayout>
